{
  "name": "gift-genie-backend",
  "version": "1.0.0",
  "description": "Backend for GiftGenie AI",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "seed:prisma": "ts-node prisma/seed.ts",
    "seed": "ts-node src/seed_pg.ts",
    "ml": "python3 ml/app.py"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.11.3",
    "razorpay": "^2.9.2"
  },
  "devDependencies": {
    "@prisma/client": "^6.19.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.4",
    "@types/pg": "^8.20.0",
    "@types/razorpay": "^2.0.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "prisma": "^6.19.2",
    "tailwindcss": "^4.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}