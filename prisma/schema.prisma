// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  mbtiType  String?
  gifts     Gift[]
  favorites Favorite[]
  customizations Customization[]
  occasions Occasion[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Gift {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  price       Float
  category    String
  tags        String[]
  mbtiType    String?
  imageUrl    String?
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id])
  favoredBy   Favorite[]
  customizations Customization[]
  occasions   Occasion[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Customization {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  giftId    Int
  gift      Gift     @relation(fields: [giftId], references: [id])
  nameText  String?
  message   String?
  photoUrl  String?
  colorTheme String?
  fontStyle String?
  createdAt DateTime @default(now())
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  giftId    Int
  gift      Gift     @relation(fields: [giftId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, giftId])
}

model Occasion {
  id        Int      @id @default(autoincrement())
  name      String
  date      DateTime
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  giftId    Int?
  gift      Gift?    @relation(fields: [giftId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
